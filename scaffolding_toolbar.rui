  <macros>
    <!-- RSDesign macros -->
    <macro_item guid="a1b2c3d4-2222-4aaa-b222-000000000001">
      <text>
        <locale_1033>RSBarSnap</locale_1033>
      </text>
      <tooltip>
        <locale_1033>Snap a new bar onto an existing bar at contact distance</locale_1033>
      </tooltip>
      <button_text>
        <locale_1033>RSBarSnap</locale_1033>
      </button_text>
      <script>! _-ScriptEditor _R "rs_bar_snap.py"</script>
    </macro_item>
    <macro_item guid="a1b2c3d4-2222-4aaa-b222-000000000002">
